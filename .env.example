# Ark API Key，不要提交真实 key。
# Docker 构建时会 COPY 进镜像，构建前请在本机填写；不要把含真实 key 的镜像推到公共仓库。
ARK_API_KEY=

# 默认 Doubao 模型；下面某个专用模型没填时会回退到它。
DOUBAO_AGENT_MODEL=doubao-seed-2-1-pro-260628

# 商品/模特图片分析模型：负责看图，输出颜色、版型、材质、细节、模特脸和发型。
DOUBAO_ANALYSIS_MODEL=doubao-seed-2-1-pro-260628

# Prompt 生成模型：负责把分析 JSON 写成 6 条日系电商 Seedream Prompt；建议用纯文本快模型。
DOUBAO_PROMPT_MODEL=doubao-seed-2-1-pro-260628

# Seedream 官方模型 ID；没有 ARK_IMAGE_MODEL 时才用它。
SEEDDREAM_MODEL=doubao-seedream-5-0-260128

# Seedream 出图 Endpoint ID；填 ep-m-xxx 后图片生成会优先使用它。
ARK_IMAGE_MODEL=

# Seedream 图片生成接口。
SEEDDREAM_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations

# Seedream 出图尺寸和格式；3:4 且满足接口最小像素要求。
SEEDDREAM_IMAGE_SIZE=1728x2304
SEEDDREAM_RESPONSE_FORMAT=png

# Ark 通用超时时间，单位毫秒；0=不主动超时，一直等 Ark 返回。
ARK_TIMEOUT_MS=180000

# Doubao 图片分析的单独超时时间，单位毫秒；0=不主动超时。
DOUBAO_ANALYSIS_TIMEOUT_MS=90000

# Doubao Prompt 生成的单独超时时间，单位毫秒；0=不主动超时。
DOUBAO_PROMPT_TIMEOUT_MS=90000

# 精修模式开关：true=Doubao 分析/Prompt 失败就停止；false 且 PLAN_FALLBACK_ON_ERROR=true 时才回退极速。
DOUBAO_PLAN_REQUIRED=true
PLAN_FALLBACK_ON_ERROR=false

# 是否把商品图/模特图作为参考图传给 Seedream，保证衣服和人脸尽量一致。
REFERENCE_IMAGE_MODE=true

# Seedream 参考图字段名；当前实测 image 可用。
SEEDDREAM_REFERENCE_FIELD=image

# Docker 部署时需监听所有网卡。
HOST=0.0.0.0

# 本地 Web 服务端口。
PORT=4173
